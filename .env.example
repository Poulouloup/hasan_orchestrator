# Copier ce fichier en .env et adapter les valeurs.
# Générer une clé admin avec : openssl rand -hex 32

ORCHESTRATOR_ADMIN_KEY=
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8080
MCP_PORT=8643

COMMAND_TTL_SECONDS=30
HEARTBEAT_INTERVAL=30
HEARTBEAT_TIMEOUT_MULTIPLIER=2
LONG_POLL_TIMEOUT=55

COMMAND_RESULT_TIMEOUT=25
COMMAND_POLL_INTERVAL_MS=500

DATABASE_PATH=~/.hasan-orchestrator/registry.db

LOG_LEVEL=INFO
